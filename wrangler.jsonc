{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "matty-dev",
  "compatibility_date": "2026-04-16",
  "observability": {
    "enabled": true
  },
  "main": "src/worker.ts",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "run_worker_first": true
  }
}
