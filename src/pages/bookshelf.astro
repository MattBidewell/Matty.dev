---
import BaseLayout from "../layouts/BaseLayout.astro";
import Book from "../components/book/Book.astro";
import { books, type IBook } from "../data/books";
import styles from "../components/book/books.module.css";

function groupBooksByYear(items: IBook[]): Map<number, IBook[]> {
  const sorted = [...items].sort((a, b) => b.date.getTime() - a.date.getTime());
  const grouped = new Map<number, IBook[]>();
  for (const book of sorted) {
    const year = book.date.getFullYear();
    if (!grouped.has(year)) grouped.set(year, []);
    grouped.get(year)!.push(book);
  }
  return grouped;
}

const yearGroups = Array.from(groupBooksByYear(books).entries());
---

<BaseLayout title="Bookshelf">
  <div class:list={["container", styles.container]}>
    <h1>Bookshelf</h1>
    <p class={styles.intro}>
      A running log of the books that stuck with me, from engineering and
      systems work to sci-fi, fantasy, and the odd health rabbit hole.
    </p>

    <div class={styles["year-list"]}>
      {
        yearGroups.map(([year, yearBooks]) => (
          <section class={styles["year-section"]}>
            <h2 class={styles["year-heading"]}>{year}</h2>
            <div class={styles["book-shelf"]}>
              {yearBooks.map((book) => (
                <Book book={book} />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
