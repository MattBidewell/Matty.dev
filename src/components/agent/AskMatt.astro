---
import styles from "./AskMatt.module.css";

const agentUrl = import.meta.env.PUBLIC_AGENT_URL ?? "";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
const maxUserTurns = 5;
const maxMessageLength = 500;

const suggestions = [
  "What does Matt work on?",
  "What has Matt been writing about lately?",
  "What projects has Matt shipped?",
];
---

<div
  class={styles.agent}
  data-ask-matt
  data-agent-url={agentUrl}
  data-turnstile-site-key={turnstileSiteKey}
  data-max-turns={maxUserTurns}
>
  <header class={styles.topBar}>
    <a href="/" class={styles.backLink} aria-label="Back to matty.dev">
      <svg class={styles.backIcon} viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>matty.dev</span>
    </a>
    <span class={styles.title}>ask matt</span>
    <span class={styles.spacer} aria-hidden="true"></span>
  </header>

  <main class={styles.scrollArea} data-scroll>
    <div class={styles.messagesInner} data-messages>
      <div class={styles.empty} data-empty-state>
        <img src="/avatar.webp" class={styles.emptyAvatar} alt="" aria-hidden="true" />
        <h1 class={styles.emptyTitle}>Ask Matt</h1>
        <p class={styles.emptyCopy}>
          A guardrailed agent answering questions about Matt's work, writing,
          and projects. It can't answer anything outside that scope.
        </p>
        <div class={styles.suggestions}>
          {suggestions.map((s) => (
            <button type="button" class={styles.suggestion} data-suggestion={s}>
              {s}
            </button>
          ))}
        </div>
      </div>
    </div>
  </main>

  <form class={styles.composer} data-form>
    <div class={styles.composerInner}>
      <div class={styles.inputWrap}>
        <label class={styles.srOnly} for="ask-matt-input">Your question</label>
        <textarea
          id="ask-matt-input"
          class={styles.textarea}
          name="message"
          rows="1"
          maxlength={maxMessageLength}
          placeholder="Ask something about Matt..."
          required
          data-input
        ></textarea>
        <button type="submit" class={styles.sendButton} data-submit aria-label="Send">
          <svg class={styles.sendIcon} viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
            <path d="M8 13V3M8 3L3.5 7.5M8 3l4.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
      <p class={styles.status} data-status role="status"></p>
      <div class={styles.turnstileWrap} data-turnstile></div>
      <p class={styles.footnote}>
        Capped at {maxUserTurns} messages per session. Protected by Cloudflare Turnstile.
      </p>
    </div>
  </form>
</div>

<script is:inline define:vars={{ classes: {
  message: styles.message,
  messageUser: styles.messageUser,
  messageAgent: styles.messageAgent,
  avatar: styles.avatar,
  bubble: styles.bubble,
  thinking: styles.thinking,
  thinkingDot: styles.thinkingDot,
  statusError: styles.statusError,
} }}>
  (function () {
    const TURNSTILE_SRC = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
    const AVATAR_SRC = "/avatar.webp";

    function loadTurnstile() {
      if (window.__turnstilePromise) return window.__turnstilePromise;
      window.__turnstilePromise = new Promise(function (resolve, reject) {
        if (window.turnstile) { resolve(window.turnstile); return; }
        const s = document.createElement("script");
        s.src = TURNSTILE_SRC;
        s.async = true;
        s.defer = true;
        s.onload = function () { resolve(window.turnstile); };
        s.onerror = function () { reject(new Error("Failed to load Turnstile")); };
        document.head.appendChild(s);
      });
      return window.__turnstilePromise;
    }

    function init(root) {
      if (!root || root.dataset.initialized === "true") return;
      root.dataset.initialized = "true";

      const agentUrl = root.dataset.agentUrl || "";
      const siteKey = root.dataset.turnstileSiteKey || "";
      const maxTurns = parseInt(root.dataset.maxTurns || "5", 10);

      const scrollEl = root.querySelector("[data-scroll]");
      const messagesEl = root.querySelector("[data-messages]");
      const emptyEl = root.querySelector("[data-empty-state]");
      const form = root.querySelector("[data-form]");
      const input = root.querySelector("[data-input]");
      const submit = root.querySelector("[data-submit]");
      const statusEl = root.querySelector("[data-status]");
      const turnstileEl = root.querySelector("[data-turnstile]");

      const history = [];
      let widgetId = null;
      let currentToken = "";
      let busy = false;
      let thinkingEl = null;

      function setStatus(text, isError) {
        statusEl.textContent = text || "";
        statusEl.classList.toggle(classes.statusError, !!isError);
      }

      function setBusy(next) {
        busy = next;
        submit.disabled = next;
      }

      function autoGrow() {
        input.style.height = "auto";
        input.style.height = Math.min(input.scrollHeight, 192) + "px";
      }

      function scrollToBottom() {
        scrollEl.scrollTop = scrollEl.scrollHeight;
      }

      function removeEmptyState() {
        if (emptyEl && emptyEl.parentNode) emptyEl.remove();
      }

      function appendMessage(role, content) {
        removeEmptyState();
        const wrap = document.createElement("div");
        wrap.className = classes.message + " " + (role === "user" ? classes.messageUser : classes.messageAgent);

        if (role === "agent") {
          const img = document.createElement("img");
          img.src = AVATAR_SRC;
          img.alt = "";
          img.setAttribute("aria-hidden", "true");
          img.className = classes.avatar;
          wrap.appendChild(img);
        }

        const body = document.createElement("div");
        body.className = classes.bubble;
        body.textContent = content;
        wrap.appendChild(body);

        messagesEl.appendChild(wrap);
        scrollToBottom();
        return wrap;
      }

      function showThinking() {
        removeEmptyState();
        const wrap = document.createElement("div");
        wrap.className = classes.message + " " + classes.messageAgent;

        const img = document.createElement("img");
        img.src = AVATAR_SRC;
        img.alt = "";
        img.setAttribute("aria-hidden", "true");
        img.className = classes.avatar;
        wrap.appendChild(img);

        const body = document.createElement("div");
        body.className = classes.bubble + " " + classes.thinking;
        for (let i = 0; i < 3; i++) {
          const dot = document.createElement("span");
          dot.className = classes.thinkingDot;
          body.appendChild(dot);
        }
        wrap.appendChild(body);

        messagesEl.appendChild(wrap);
        thinkingEl = wrap;
        scrollToBottom();
      }

      function clearThinking() {
        if (thinkingEl && thinkingEl.parentNode) thinkingEl.remove();
        thinkingEl = null;
      }

      function userTurnCount() {
        return history.filter(function (m) { return m.role === "user"; }).length;
      }

      function renderTurnstile() {
        if (!siteKey) {
          setStatus("Agent not configured (missing site key).", true);
          return Promise.reject(new Error("missing site key"));
        }
        return loadTurnstile().then(function (turnstile) {
          widgetId = turnstile.render(turnstileEl, {
            sitekey: siteKey,
            size: "flexible",
            appearance: "interaction-only",
            callback: function (token) { currentToken = token; },
            "error-callback": function () {
              currentToken = "";
              setStatus("Verification failed. Please refresh the page.", true);
            },
            "expired-callback": function () {
              currentToken = "";
              if (window.turnstile && widgetId !== null) window.turnstile.reset(widgetId);
            },
          });
        });
      }

      function resetTurnstile() {
        if (window.turnstile && widgetId !== null) {
          currentToken = "";
          window.turnstile.reset(widgetId);
        }
      }

      async function submitMessage(content) {
        if (!agentUrl) { setStatus("Agent URL not configured.", true); return; }
        if (userTurnCount() >= maxTurns) {
          setStatus("You've reached the message limit for this session. Refresh to start over.", true);
          return;
        }

        setBusy(true);
        setStatus("", false);
        appendMessage("user", content);
        history.push({ role: "user", content: content });
        showThinking();

        try {
          const res = await fetch(agentUrl.replace(/\/$/, "") + "/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ turnstileToken: currentToken, messages: history }),
          });

          clearThinking();

          if (!res.ok) {
            let detail = "";
            try {
              const errJson = await res.json();
              detail = errJson.error || errJson.message || "";
            } catch (e) {}
            if (res.status === 429) setStatus("Too many requests. Please slow down.", true);
            else if (res.status === 403) setStatus("Verification failed. Please refresh and try again.", true);
            else if (res.status === 503) setStatus(detail || "The agent is temporarily unavailable.", true);
            else setStatus(detail || ("Something went wrong (" + res.status + ")."), true);
            history.pop();
            return;
          }

          const data = await res.json();
          const reply = (data && data.reply) || "";
          if (!reply) {
            setStatus("The agent returned an empty response.", true);
            history.pop();
            return;
          }
          appendMessage("agent", reply);
          history.push({ role: "assistant", content: reply });

          if (userTurnCount() >= maxTurns) {
            setStatus("Session limit reached. Refresh to start over.", false);
            input.disabled = true;
            submit.disabled = true;
            return;
          }
        } catch (err) {
          clearThinking();
          setStatus("Couldn't reach the agent. Check your connection and try again.", true);
          history.pop();
        } finally {
          resetTurnstile();
          if (userTurnCount() < maxTurns) setBusy(false);
        }
      }

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        if (busy) return;
        const content = (input.value || "").trim();
        if (!content) return;
        input.value = "";
        autoGrow();
        submitMessage(content);
      });

      input.addEventListener("keydown", function (e) {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          form.requestSubmit();
        }
      });

      input.addEventListener("input", autoGrow);

      root.querySelectorAll("[data-suggestion]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          const text = btn.dataset.suggestion || "";
          if (!text || busy) return;
          submitMessage(text);
        });
      });

      renderTurnstile().catch(function () {
        setStatus("Couldn't load verification. Please refresh the page.", true);
      });

      autoGrow();
      input.focus();
    }

    function initAll() {
      document.querySelectorAll("[data-ask-matt]").forEach(init);
    }

    initAll();
    document.addEventListener("astro:page-load", initAll);
  })();
</script>
