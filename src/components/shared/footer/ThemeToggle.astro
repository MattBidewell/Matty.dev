---
import styles from "./Footer.module.css";

const activeClass = styles.themeButtonActive;
---

<div class={styles.themeToggle} role="group" aria-label="Theme switcher" data-theme-toggle>
  <button
    type="button"
    class={styles.themeButton}
    data-theme-button="light"
    aria-pressed="false"
  >
    light
  </button>
  <span class={styles.separator}>/</span>
  <button
    type="button"
    class={styles.themeButton}
    data-theme-button="dark"
    aria-pressed="false"
  >
    dark
  </button>
</div>

<script is:inline define:vars={{ activeClass }}>
  (function () {
    const STORAGE_KEY = "theme-preference";
    const TRANSITION_CLASS = "theme-changing";

    function resolveTheme() {
      const explicit = document.documentElement.dataset.theme;
      if (explicit === "light" || explicit === "dark") return explicit;
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    function syncButtons(theme) {
      document
        .querySelectorAll("[data-theme-button]")
        .forEach(function (btn) {
          const isActive = btn.dataset.themeButton === theme;
          btn.classList.toggle(activeClass, isActive);
          btn.setAttribute("aria-pressed", String(isActive));
        });
    }

    function setTheme(next) {
      document.documentElement.classList.add(TRANSITION_CLASS);
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem(STORAGE_KEY, next);
      } catch (e) {}
      syncButtons(next);
      window.setTimeout(function () {
        document.documentElement.classList.remove(TRANSITION_CLASS);
      }, 250);
    }

    function init() {
      syncButtons(resolveTheme());
      document
        .querySelectorAll("[data-theme-button]")
        .forEach(function (btn) {
          btn.addEventListener("click", function () {
            const next = btn.dataset.themeButton;
            if (next === "light" || next === "dark") setTheme(next);
          });
        });
      const mq = window.matchMedia("(prefers-color-scheme: dark)");
      mq.addEventListener("change", function () {
        syncButtons(resolveTheme());
      });
    }

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
