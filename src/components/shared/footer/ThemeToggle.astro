---
import styles from "./Footer.module.css";

const activeClass = styles.themeButtonActive;

const themes = [
  { id: "system", label: "system" },
  { id: "gruvbox-light", label: "gruvbox-light" },
  { id: "gruvbox-dark", label: "gruvbox-dark" },
  { id: "tokyo-night", label: "tokyo-night" },
];
---

<div class={styles.themeToggle} role="group" aria-label="Theme switcher" data-theme-toggle>
  <span class={styles.themePrompt} aria-hidden="true">:set theme=</span>
  <select
    class={styles.themeSelect}
    data-theme-select
    aria-label="Select theme"
  >
    {themes.map((t) => (
      <option value={t.id}>{t.label}</option>
    ))}
  </select>
</div>

<script is:inline define:vars={{ activeClass }}>
  (function () {
    const STORAGE_KEY = "theme-preference";
    const TRANSITION_CLASS = "theme-changing";
    const VALID = ["gruvbox-light", "gruvbox-dark", "tokyo-night"];

    function currentPref() {
      try {
        const v = localStorage.getItem(STORAGE_KEY);
        if (v && VALID.indexOf(v) !== -1) return v;
      } catch (e) {}
      return "system";
    }

    function applyTheme(pref) {
      document.documentElement.classList.add(TRANSITION_CLASS);
      if (pref === "system") {
        delete document.documentElement.dataset.theme;
        try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      } else if (VALID.indexOf(pref) !== -1) {
        document.documentElement.dataset.theme = pref;
        try { localStorage.setItem(STORAGE_KEY, pref); } catch (e) {}
      }
      window.setTimeout(function () {
        document.documentElement.classList.remove(TRANSITION_CLASS);
      }, 240);
    }

    function syncSelect() {
      const pref = currentPref();
      document.querySelectorAll("[data-theme-select]").forEach(function (el) {
        if (el.value !== pref) el.value = pref;
      });
    }

    function init() {
      syncSelect();
      document.querySelectorAll("[data-theme-select]").forEach(function (el) {
        el.addEventListener("change", function (e) {
          applyTheme(e.target.value);
        });
      });
    }

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
