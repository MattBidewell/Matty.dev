---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/newsreader/500.css";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ask Matt",
  description = "A guardrailed AI agent that answers questions about Matt Bidewell.",
} = Astro.props;

const fullTitle = `${title} | Matty.dev`;
const url = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL("/avatar.webp", Astro.site).toString();
---

<html lang="en" style="--font-sans: 'Inter'; --font-serif: 'Newsreader';">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Matthew Bidewell" />
    <meta name="robots" content="noindex" />

    <link rel="canonical" href={url} />
    <link rel="icon" type="image/webp" href="/avatar.webp" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImageUrl} />

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem("theme-preference");
          if (theme === "light" || theme === "dark") {
            document.documentElement.dataset.theme = theme;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="agent-body">
    <slot />

    <style is:global>
      html, body.agent-body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-image: none;
      }
      body.agent-body {
        background-color: var(--bg-color);
      }
    </style>
  </body>
</html>
