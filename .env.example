# Ask Matt agent (UI side)
# Both vars are PUBLIC — baked into the client bundle at build time.
# The actual values are configured in the Cloudflare dashboard for prod.

# Base URL of the agent Worker (private repo: matty-agent).
# Dev: http://localhost:8787
# Prod: https://agent.matty.dev
PUBLIC_AGENT_URL=http://localhost:8787

# Cloudflare Turnstile site key (public half of the keypair).
# Configure allowed hostnames in the Turnstile dashboard to include
# matty.dev and localhost.
# Use the "always passes" test key (1x00000000000000000000AA) for local dev.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
